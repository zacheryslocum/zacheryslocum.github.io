---
const {title, text, footer} = Astro.props;
export interface Props {
  title: string;
  text: string;
  footer: string;
}
---
<div class="card border-primary">
    <h4 class="card-header bg-primary">{title}</h4>
    <div class="progress bg-light">
        <div
            class="progress-bar progress-bar-striped bg-success"
            role="progressbar"
            aria-valuenow="100"
            aria-valuemin="0"
            aria-valuemax="100"
            style="width: 100%"
        >
        </div>
    </div>
    <div class="card-body">
        <div class="card-text">
            {text}
        </div><!-- end card-text -->
    </div>
    <!-- end card body -->
    <div class="card-footer bg-dark">
        {footer}
    </div>
</div>
<!-- end card -->
